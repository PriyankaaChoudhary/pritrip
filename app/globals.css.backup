/* ============================================
   PUBLIC SITE STYLES — restores the original HTML design
   Scoped under .pritrip-public so it doesn't leak into admin
   ============================================ */

.pritrip-public {
  /* Palette from original HTML */
  --p-ink: #0e0e12;
  --p-paper: #fef8ed;
  --p-paper-warm: #f7ead1;
  --p-cherry: #ff3b3b;
  --p-lime: #c7ff3f;
  --p-sky: #7cc7ff;
  --p-plum: #6f47ff;
  --p-sun: #ffcc3f;
  --p-pine: #0b6b4a;
  --p-ice: #d7eeff;
  --p-blossom: #ffcfe6;
  --p-ember: #ffa24b;
  --p-snow: #f1f6fb;

  font-family: 'Bricolage Grotesque', system-ui, sans-serif;
  background: var(--p-paper);
  color: var(--p-ink);
  line-height: 1.4;
  transition: background .6s ease;
}

.pritrip-public.season-summer { background: var(--p-paper); }
.pritrip-public.season-fall    { background: #fbe8cf; }
.pritrip-public.season-winter  { background: var(--p-snow); }
.pritrip-public.season-spring  { background: #fff0f6; }

/* Noise texture overlay */
.pritrip-public::before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 1;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.5'/%3E%3C/svg%3E");
  opacity: .06;
  mix-blend-mode: multiply;
}

/* Nav */
.pt-nav {
  position: sticky;
  top: 0;
  z-index: 50;
  backdrop-filter: blur(12px);
  background: rgba(254, 248, 237, .8);
  border-bottom: 2px solid var(--p-ink);
}
.pt-nav-inner {
  max-width: 1400px;
  margin: 0 auto;
  padding: 14px 28px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  letter-spacing: -.5px;
  text-decoration: none;
  color: inherit;
}
.pt-logo {
  font-family: 'Instrument Serif', serif;
  font-size: 32px;
  font-style: italic;
  display: flex;
  align-items: center;
  gap: 6px;
  letter-spacing: -.5px;
}
.pt-logo span {
  background: var(--p-cherry);
  color: var(--p-paper);
  padding: 2px 10px;
  border-radius: 999px;
  font-family: 'Bricolage Grotesque';
  font-style: normal;
  font-weight: 800;
  font-size: 22px;
  transform: rotate(-4deg);
  display: inline-block;
}
.pt-nav-links { display: flex; gap: 28px; font-weight: 600; font-size: 15px; }
.pt-nav-links a { position: relative; padding: 4px 2px; color: inherit; text-decoration: none; }
.pt-nav-links a::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -2px;
  height: 3px;
  width: 0;
  background: var(--p-cherry);
  transition: width .3s;
}
.pt-nav-links a:hover::after { width: 100%; }
.pt-nav-cta {
  background: var(--p-ink);
  color: var(--p-paper);
  padding: 10px 20px;
  border-radius: 999px;
  font-weight: 700;
  font-size: 14px;
  border: 2px solid var(--p-ink);
  transition: transform .2s;
  text-decoration: none;
  display: inline-block;
}
.pt-nav-cta:hover { transform: translate(-2px, -2px); box-shadow: 4px 4px 0 var(--p-cherry); }
@media (max-width: 700px) { .pt-nav-links { display: none; } }

/* Hero */
.pt-hero { position: relative; padding: 80px 28px 60px; max-width: 1400px; margin: 0 auto; overflow: hidden; }
.pt-hero-tag {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--p-lime);
  border: 2px solid var(--p-ink);
  padding: 8px 16px;
  border-radius: 999px;
  font-weight: 700;
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: 1px;
  transform: rotate(-2deg);
  margin-bottom: 30px;
  box-shadow: 4px 4px 0 var(--p-ink);
}
.pt-hero-tag .dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  background: var(--p-cherry);
  animation: pt-pulse 1.5s infinite;
}
@keyframes pt-pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50%      { transform: scale(1.4); opacity: .6; }
}
.pt-hero-title {
  font-size: clamp(56px, 11vw, 180px);
  font-weight: 800;
  line-height: .88;
  letter-spacing: -.04em;
  margin-bottom: 30px;
}
.pt-hero-title .italic {
  font-family: 'Instrument Serif', serif;
  font-style: italic;
  font-weight: 400;
  color: var(--p-cherry);
}
.pt-hero-title .sticker {
  display: inline-block;
  background: var(--p-sun);
  padding: 0 14px;
  transform: rotate(-3deg);
  border: 3px solid var(--p-ink);
  border-radius: 16px;
}
.pt-hero-sub {
  font-size: clamp(18px, 2vw, 22px);
  max-width: 640px;
  margin-bottom: 34px;
  font-weight: 500;
}

/* Counter strip */
.pt-counter {
  display: flex;
  gap: 30px;
  flex-wrap: wrap;
  margin-bottom: 40px;
  padding: 20px 0;
  border-top: 2px solid var(--p-ink);
  border-bottom: 2px solid var(--p-ink);
  max-width: 720px;
}
.pt-counter .stat { display: flex; flex-direction: column; gap: 2px; }
.pt-counter .num { font-size: 36px; font-weight: 800; letter-spacing: -.03em; line-height: 1; }
.pt-counter .num .italic {
  font-family: 'Instrument Serif', serif;
  font-style: italic;
  font-weight: 400;
  color: var(--p-cherry);
}
.pt-counter .lbl {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 1px;
  opacity: .6;
}

/* Hero buttons */
.pt-hero-actions { display: flex; gap: 16px; flex-wrap: wrap; }
.pt-btn-primary {
  background: var(--p-cherry);
  color: var(--p-paper);
  padding: 18px 34px;
  border-radius: 999px;
  font-weight: 700;
  font-size: 16px;
  border: 3px solid var(--p-ink);
  box-shadow: 6px 6px 0 var(--p-ink);
  transition: all .2s;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
}
.pt-btn-primary:hover { transform: translate(-3px, -3px); box-shadow: 9px 9px 0 var(--p-ink); }
.pt-btn-secondary {
  background: var(--p-paper);
  color: var(--p-ink);
  padding: 18px 34px;
  border-radius: 999px;
  font-weight: 700;
  font-size: 16px;
  border: 3px solid var(--p-ink);
  transition: all .2s;
  text-decoration: none;
  display: inline-block;
}
.pt-btn-secondary:hover { background: var(--p-ink); color: var(--p-paper); }

/* Floating stickers */
.pt-floater {
  position: absolute;
  border: 3px solid var(--p-ink);
  border-radius: 20px;
  padding: 12px 18px;
  font-weight: 700;
  font-size: 14px;
  box-shadow: 5px 5px 0 var(--p-ink);
  pointer-events: none;
  animation: pt-bob 4s ease-in-out infinite;
}
@keyframes pt-bob {
  0%, 100% { transform: translateY(0) rotate(var(--r, 0deg)); }
  50%      { transform: translateY(-12px) rotate(var(--r, 0deg)); }
}
.pt-floater.f1 { top: 110px; right: 8%;  background: var(--p-sky);     --r: 6deg;  animation-delay: 0s; }
.pt-floater.f2 { top: 260px; right: 22%; background: var(--p-blossom); --r: -8deg; animation-delay: .8s; }
.pt-floater.f3 { bottom: 80px; right: 4%; background: var(--p-lime);    --r: 4deg;  animation-delay: 1.4s; }
@media (max-width: 900px) { .pt-floater { display: none; } }

/* Section heading label */
.pt-section-label {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 20px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: 2px;
  font-weight: 600;
}
.pt-section-label::before { content: ""; width: 40px; height: 2px; background: var(--p-ink); }

/* World map section */
.pt-world { max-width: 1400px; margin: 0 auto; padding: 40px 28px 60px; }
.pt-world-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  flex-wrap: wrap;
  gap: 20px;
  margin-bottom: 30px;
}
.pt-world-header h2 {
  font-size: clamp(40px, 6vw, 80px);
  font-weight: 800;
  letter-spacing: -.03em;
  line-height: .95;
  max-width: 720px;
}
.pt-world-header h2 .italic {
  font-family: 'Instrument Serif', serif;
  font-style: italic;
  font-weight: 400;
  color: var(--p-plum);
}
.pt-world-header p { max-width: 340px; font-size: 16px; opacity: .75; }

.pt-world-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: 30px; }
@media (max-width: 1000px) { .pt-world-grid { grid-template-columns: 1fr; } }

.pt-world-map-wrap {
  position: relative;
  background: var(--p-paper-warm);
  border: 3px solid var(--p-ink);
  border-radius: 32px;
  padding: 24px;
  overflow: hidden;
  box-shadow: 10px 10px 0 var(--p-ink);
}
.pt-world-map-wrap::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle at 1px 1px, rgba(14, 14, 18, .12) 1px, transparent 0);
  background-size: 20px 20px;
  opacity: .6;
}
.pt-world-svg { width: 100%; height: auto; position: relative; z-index: 2; display: block; }
.pt-continent {
  fill: var(--p-paper);
  stroke: var(--p-ink);
  stroke-width: 2;
  stroke-linejoin: round;
  cursor: pointer;
  transition: fill .2s;
}
.pt-continent.active      { fill: var(--p-cherry); }
.pt-continent.has-content { fill: var(--p-sun); }
.pt-continent:hover       { fill: var(--p-lime); }
.pt-continent.active:hover { fill: var(--p-cherry); }
.pt-cont-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  font-weight: 700;
  fill: var(--p-ink);
  pointer-events: none;
  text-anchor: middle;
}
.pt-count-badge {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px;
  font-weight: 700;
  fill: var(--p-paper);
  pointer-events: none;
  text-anchor: middle;
}

.pt-region-panel {
  background: var(--p-ink);
  color: var(--p-paper);
  border-radius: 32px;
  padding: 30px;
  display: flex;
  flex-direction: column;
  gap: 18px;
  box-shadow: 10px 10px 0 var(--p-ink);
  border: 3px solid var(--p-ink);
}
.pt-region-panel h3 { font-size: 28px; font-weight: 800; letter-spacing: -.02em; }
.pt-region-panel .sub {
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  opacity: .6;
}
.pt-region-list { display: flex; flex-direction: column; gap: 10px; flex: 1; }
.pt-region-item {
  padding: 14px 18px;
  border: 2px solid rgba(254, 248, 237, .2);
  border-radius: 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: all .2s;
  cursor: pointer;
  text-decoration: none;
  color: inherit;
}
.pt-region-item:hover { background: rgba(254, 248, 237, .08); border-color: var(--p-lime); }
.pt-region-item.live  { border-color: var(--p-lime); background: rgba(199, 255, 63, .08); }
.pt-region-item .name { font-weight: 700; font-size: 16px; }
.pt-region-item .status {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  padding: 4px 10px;
  border-radius: 999px;
  text-transform: uppercase;
  letter-spacing: 1px;
}
.pt-region-item.live .status { background: var(--p-lime); color: var(--p-ink); font-weight: 700; }
.pt-region-item:not(.live) .status { background: rgba(254, 248, 237, .1); opacity: .6; }
.pt-region-vote {
  padding: 12px 16px;
  background: rgba(254, 248, 237, .06);
  border-radius: 16px;
  font-size: 13px;
  opacity: .8;
  text-align: center;
}
.pt-region-vote a { color: var(--p-lime); font-weight: 700; text-decoration: underline; }

/* Seasons */
.pt-seasons { max-width: 1400px; margin: 0 auto; padding: 40px 28px 20px; }
.pt-seasons-header {
  margin-bottom: 24px;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  flex-wrap: wrap;
  gap: 12px;
}
.pt-seasons-header h2 {
  font-size: clamp(32px, 4.5vw, 56px);
  font-weight: 800;
  letter-spacing: -.02em;
  line-height: 1;
}
.pt-seasons-header h2 .italic {
  font-family: 'Instrument Serif', serif;
  font-style: italic;
  font-weight: 400;
  color: var(--p-cherry);
}
.pt-now-showing {
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  background: var(--p-ink);
  color: var(--p-paper);
  padding: 8px 14px;
  border-radius: 999px;
}
.pt-now-showing .flag { margin-right: 4px; }

.pt-season-tabs {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
  margin-bottom: 40px;
}
@media (max-width: 700px) { .pt-season-tabs { grid-template-columns: repeat(2, 1fr); } }
.pt-season-tab {
  border: 3px solid var(--p-ink);
  border-radius: 24px;
  padding: 24px 20px;
  text-align: left;
  position: relative;
  transition: all .25s;
  overflow: hidden;
  background: var(--p-paper-warm);
  cursor: pointer;
  font-family: inherit;
}
.pt-season-tab:hover { transform: translate(-3px, -3px); box-shadow: 8px 8px 0 var(--p-ink); }
.pt-season-tab.active { box-shadow: 6px 6px 0 var(--p-ink); transform: translate(-2px, -2px); }
.pt-season-tab[data-season="summer"].active { background: var(--p-sun); }
.pt-season-tab[data-season="fall"].active   { background: var(--p-ember); }
.pt-season-tab[data-season="winter"].active { background: var(--p-ice); }
.pt-season-tab[data-season="spring"].active { background: var(--p-blossom); }
.pt-season-emoji { font-size: 40px; display: block; margin-bottom: 8px; }
.pt-season-name  { font-size: 22px; font-weight: 800; letter-spacing: -.02em; }
.pt-season-meta  { font-size: 13px; font-weight: 500; opacity: .7; margin-top: 4px; }

/* Trips grid */
.pt-trips-grid {
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  gap: 20px;
  margin-bottom: 30px;
}
.pt-trip-card {
  border: 3px solid var(--p-ink);
  border-radius: 28px;
  overflow: hidden;
  background: var(--p-paper);
  transition: transform .3s;
  position: relative;
  text-decoration: none;
  color: inherit;
  display: block;
}
.pt-trip-card:hover { transform: translateY(-6px); }
.pt-trip-card .media {
  aspect-ratio: 4/3;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Instrument Serif', serif;
  font-style: italic;
  color: var(--p-paper);
  font-size: 18px;
}
.pt-trip-card .media img {
  position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
}
.pt-trip-card .body { padding: 20px 22px 24px; }
.pt-trip-card h3 {
  font-size: 22px;
  font-weight: 800;
  letter-spacing: -.02em;
  margin-bottom: 6px;
  line-height: 1.1;
}
.pt-trip-card .loc {
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  text-transform: uppercase;
  opacity: .6;
  margin-bottom: 12px;
}
.pt-trip-card .tags { display: flex; gap: 6px; flex-wrap: wrap; }
.pt-trip-card .tag {
  font-size: 11px;
  font-weight: 600;
  padding: 4px 10px;
  border: 1.5px solid var(--p-ink);
  border-radius: 999px;
}
.pt-trip-card.big   { grid-column: span 7; }
.pt-trip-card.big .media { aspect-ratio: 16/10; }
.pt-trip-card.big h3 { font-size: 32px; }
.pt-trip-card.sm    { grid-column: span 5; }
.pt-trip-card.third { grid-column: span 4; }
@media (max-width: 900px) {
  .pt-trip-card.big, .pt-trip-card.sm, .pt-trip-card.third { grid-column: span 12; }
}

/* Media placeholders (when no image uploaded) */
.season-summer .pt-trip-card .media-placeholder-1 { background: linear-gradient(135deg, #1e90ff, #7cc7ff 60%, #c7ff3f); }
.season-summer .pt-trip-card .media-placeholder-2 { background: linear-gradient(135deg, #ff9f45, #ffcc3f); }
.season-summer .pt-trip-card .media-placeholder-3 { background: linear-gradient(135deg, #0b6b4a, #4eb87b); }
.season-fall .pt-trip-card .media-placeholder-1   { background: linear-gradient(135deg, #c1440e, #ff9f45, #ffcc3f); }
.season-fall .pt-trip-card .media-placeholder-2   { background: linear-gradient(135deg, #6a1f1f, #c1440e); }
.season-fall .pt-trip-card .media-placeholder-3   { background: linear-gradient(135deg, #3a4a1f, #8a6e2f); }
.season-winter .pt-trip-card .media-placeholder-1 { background: linear-gradient(135deg, #6f9dd9, #d7eeff); }
.season-winter .pt-trip-card .media-placeholder-2 { background: linear-gradient(135deg, #1e2a4a, #6f9dd9); }
.season-winter .pt-trip-card .media-placeholder-3 { background: linear-gradient(135deg, #a5b8d0, #f1f6fb); }
.season-spring .pt-trip-card .media-placeholder-1 { background: linear-gradient(135deg, #ffcfe6, #c7ff3f); }
.season-spring .pt-trip-card .media-placeholder-2 { background: linear-gradient(135deg, #8adf9d, #fff0a6); }
.season-spring .pt-trip-card .media-placeholder-3 { background: linear-gradient(135deg, #ffb3d1, #ff6fae); }

/* Activities (dark section) */
.pt-activities {
  max-width: 1400px;
  margin: 0 auto 80px;
  padding: 80px 28px;
  background: var(--p-ink);
  color: var(--p-paper);
  border-radius: 40px;
  position: relative;
  overflow: hidden;
}
@media (max-width: 900px) {
  .pt-activities { border-radius: 24px; padding: 60px 22px; margin: 0 14px 60px; }
}
.pt-activities::before {
  content: "PRITRIP PRITRIP PRITRIP PRITRIP PRITRIP PRITRIP PRITRIP PRITRIP ";
  position: absolute;
  top: 20px;
  left: 0;
  right: 0;
  font-size: 14vw;
  font-weight: 800;
  letter-spacing: -.04em;
  color: rgba(254, 248, 237, .04);
  white-space: nowrap;
  pointer-events: none;
  line-height: 1;
}
.pt-activities h2 {
  font-size: clamp(40px, 6vw, 80px);
  font-weight: 800;
  letter-spacing: -.03em;
  line-height: .95;
  margin-bottom: 12px;
  position: relative;
}
.pt-activities h2 .italic {
  font-family: 'Instrument Serif', serif;
  font-style: italic;
  font-weight: 400;
  color: var(--p-lime);
}
.pt-activities p.intro {
  font-size: 18px;
  max-width: 560px;
  opacity: .7;
  margin-bottom: 40px;
  position: relative;
}
.pt-filter-chips {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 44px;
  position: relative;
}
.pt-chip {
  padding: 12px 22px;
  border-radius: 999px;
  border: 2px solid var(--p-paper);
  color: var(--p-paper);
  font-weight: 600;
  font-size: 14px;
  transition: all .2s;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: transparent;
  cursor: pointer;
  font-family: inherit;
}
.pt-chip:hover  { background: rgba(254, 248, 237, .1); }
.pt-chip.active { background: var(--p-lime); color: var(--p-ink); border-color: var(--p-lime); }
.pt-venues {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 18px;
  position: relative;
}
.pt-venue {
  background: rgba(254, 248, 237, .06);
  border: 2px solid rgba(254, 248, 237, .2);
  border-radius: 20px;
  padding: 22px;
  transition: all .3s;
  text-decoration: none;
  color: inherit;
  display: block;
}
.pt-venue:hover { background: rgba(254, 248, 237, .12); transform: translateY(-4px); }
.pt-venue .emoji { font-size: 32px; display: block; margin-bottom: 10px; }
.pt-venue h4 {
  font-size: 19px;
  font-weight: 700;
  margin-bottom: 4px;
  letter-spacing: -.01em;
}
.pt-venue .where {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  opacity: .6;
  text-transform: uppercase;
  margin-bottom: 10px;
}
.pt-venue .desc { font-size: 14px; opacity: .85; line-height: 1.5; }

/* Blog roundup section (replaces Stories) */
.pt-blogs { max-width: 1400px; margin: 0 auto; padding: 40px 28px 80px; }
.pt-blogs-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  flex-wrap: wrap;
  gap: 20px;
  margin-bottom: 40px;
}
.pt-blogs-header h2 {
  font-size: clamp(40px, 6vw, 80px);
  font-weight: 800;
  letter-spacing: -.03em;
  line-height: .95;
}
.pt-blogs-header h2 .italic {
  font-family: 'Instrument Serif', serif;
  font-style: italic;
  font-weight: 400;
  color: var(--p-cherry);
}
.pt-blogs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
@media (max-width: 900px) { .pt-blogs-grid { grid-template-columns: 1fr; } }

.pt-blog-card {
  border: 3px solid var(--p-ink);
  border-radius: 28px;
  overflow: hidden;
  background: var(--p-paper);
  transition: transform .3s;
  position: relative;
  text-decoration: none;
  color: inherit;
  display: block;
}
.pt-blog-card:hover { transform: translateY(-4px); }
.pt-blog-card .cover {
  aspect-ratio: 16/10;
  background: linear-gradient(135deg, var(--p-plum), var(--p-cherry));
  position: relative;
}
.pt-blog-card:nth-child(3n+2) .cover { background: linear-gradient(135deg, var(--p-pine), var(--p-lime)); }
.pt-blog-card:nth-child(3n) .cover   { background: linear-gradient(135deg, var(--p-sun), var(--p-ember), var(--p-cherry)); }
.pt-blog-card .cover img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
.pt-blog-card .body { padding: 20px 22px 24px; }
.pt-blog-card .kicker {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 1px;
  opacity: .6;
  margin-bottom: 6px;
}
.pt-blog-card h3 {
  font-size: 22px;
  font-weight: 800;
  letter-spacing: -.02em;
  margin-bottom: 8px;
  line-height: 1.15;
}
.pt-blog-card .excerpt { font-size: 14px; line-height: 1.5; opacity: .8; }

.pt-blogs-empty {
  text-align: center;
  padding: 60px 20px;
  border: 3px dashed var(--p-ink);
  border-radius: 28px;
  opacity: .6;
}

/* Footer */
.pt-footer { border-top: 2px solid var(--p-ink); padding: 50px 28px 30px; max-width: 1400px; margin: 0 auto; }
.pt-foot-top { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 30px; margin-bottom: 40px; }
@media (max-width: 900px) { .pt-foot-top { grid-template-columns: 1fr 1fr; } }
.pt-foot-brand .pt-logo { margin-bottom: 10px; }
.pt-foot-brand p { font-size: 14px; max-width: 300px; opacity: .7; }
.pt-footer h5 {
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 2px;
  font-family: 'JetBrains Mono', monospace;
  margin-bottom: 14px;
}
.pt-footer ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 8px;
  font-size: 14px;
  font-weight: 500;
  padding: 0;
  margin: 0;
}
.pt-footer ul a { color: inherit; text-decoration: none; }
.pt-footer ul a:hover { color: var(--p-cherry); }
.pt-foot-bottom {
  border-top: 1px solid rgba(14, 14, 18, .15);
  padding-top: 20px;
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 10px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  opacity: .6;
}

.pritrip-public a {
  text-decoration: none;
  color: inherit;
}

.pritrip-public a:hover {
  text-decoration: none;
}